# Supabase (Project Settings > API) — clé "service_role", jamais "anon"
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gmail (envoi via ton compte, pas d'API payante) — voir README pour générer le
# "mot de passe d'application" à 16 caractères (PAS ton mot de passe Gmail normal)
GMAIL_USER=kwenistudio@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
REPLY_TO_EMAIL=kwenistudio@gmail.com

# Google AI Studio — clé API Gemini/Gemma (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Alternative plus "dense"/qualitative, même quota : gemma-4-31b-it.
# Alternative côté Gemini (moins de quota mais parfois plus fiable) : gemini-3.1-flash-lite.
GEMINI_MODEL=gemma-4-26b-a4b-it

# Nombre max d'emails envoyés / 24h, tous canaux confondus (chat). Reste prudent avec Gmail
# (compte perso, pas un service d'envoi dédié) : 20-30 au départ.
DAILY_LIMIT=30

# Optionnel mais recommandé : protège /api/cron/scrape contre les appels externes.
# Vercel l'ajoute automatiquement en en-tête Authorization quand le Cron Job se déclenche ;
# mets ici la même valeur que celle configurée dans Vercel > Settings > Environment Variables.
CRON_SECRET=choisis-une-valeur-secrete-aleatoire
